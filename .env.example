# =============================
# 选择模式
# =============================
# relay     - 直接转发到 OpenAI 兼容的图片 API 服务 (官方/otokapi/modaplex)
# chat2api  - 把图片请求翻译成 chat completion，调 chat2api/One API，从响应里抠图
MODE=chat2api

# 通用
IMAGE_MODEL=gpt-image-2
REQUEST_TIMEOUT=180

# =============================
# Relay 模式（MODE=relay 时用）
# =============================
# 这三项是默认/回退值；启动后推荐在 /admin 的「中转站生图设置」里修改，保存后无需重启。
IMAGE_API_KEY=sk-your-relay-key
IMAGE_API_BASE=https://otokapi.com/v1/images

# =============================
# chat2api 模式（MODE=chat2api 时用）
# =============================
# 走 One API 的话填 One API 地址 + One API 用户 key（推荐：能记账、限速）
CHAT_API_BASE=http://127.0.0.1:3000/v1
CHAT_API_KEY=sk-cTEYD7KvEQRJBcpHAa1833FaCc254cA880967fFe9eCa1a06

# 直接走 chat2api 的话改成（不经过 One API）：
# CHAT_API_BASE=http://127.0.0.1:5005/c2a/v1
# CHAT_API_KEY=oneapi-internal-key-d8f3a-CHANGE-ME

# 下载图片时用的代理（OpenAI CDN URL 国内可能不可达）
PROXY=http://127.0.0.1:7897
